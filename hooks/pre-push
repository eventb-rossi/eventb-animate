#!/usr/bin/env bash
set -euo pipefail

# Only validate version consistency for tag pushes.
# Normal branch pushes pass through unaffected.

while read -r local_ref local_oid remote_ref remote_oid; do
  case "$remote_ref" in
    refs/tags/v*)
      TAG="${remote_ref#refs/tags/}"
      scripts/check-version.sh "$TAG"
      ;;
  esac
done
